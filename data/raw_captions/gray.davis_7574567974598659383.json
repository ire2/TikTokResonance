": 0.0, "avg_logprob": -0.225132269937484, "compression_ratio": 1.695167286245353, "no_speech_prob": 0.0007672545616514981}, {"id": 40, "seek": 11288, "start": 125.39999999999999, "end": 130.0, "text": " They're absolutely delicious and the sugar right on top just absolutely knocks it out of the park.", "tokens": [50990, 814, 434, 3122, 4809, 293, 264, 5076, 558, 322, 1192, 445, 3122, 40815, 309, 484, 295, 264, 3884, 13, 51220], "temperature": 0.0, "avg_logprob": -0.225132269937484, "compression_ratio": 1.695167286245353, "no_speech_prob": 0.0007672545616514981}, {"id": 41, "seek": 11288, "start": 130.16, "end": 132.0, "text": " They're kind of like a coconut snickerdoodle.", "tokens": [51228, 814, 434, 733, 295, 411, 257, 13551, 2406, 618, 7783, 1816, 306, 13, 51320], "temperature": 0.0, "avg_logprob": -0.225132269937484, "compression_ratio": 1.695167286245353, "no_speech_prob": 0.0007672545616514981}, {"id": 42, "seek": 11288, "start": 133.28, "end": 133.76, "text": " Mmm.", "tokens": [51384, 12146, 13, 51408], "temperature": 0.0, "avg_logprob": -0.225132269937484, "compression_ratio": 1.695167286245353, "no_speech_prob": 0.0007672545616514981}, {"id": 43, "seek": 11288, "start": 133.92, "end": 137.92, "text": " Let me know if you'd give these a try and until next time, get outside and see what you can find.", "tokens": [51416, 961, 385, 458, 498, 291, 1116, 976, 613, 257, 853, 293, 1826, 958, 565, 11, 483, 2380, 293, 536, 437, 291, 393, 915, 13, 51616], "temperature": 0.0, "avg_logprob": -0.225132269937484, "compression_ratio": 1.695167286245353, "no_speech_prob": 0.0007672545616514981}, {"id": 44, "seek": 11288, "start": 139.28, "end": 139.68, "text": " Mmm.", "tokens": [51684, 12146, 13, 51704], "temperature": 0.0, "avg_logprob": -0.225132269937484, "compression_ratio": 1.695167286245353, "no_speech_prob": 0.0007672545616514981}], "language": "en"}