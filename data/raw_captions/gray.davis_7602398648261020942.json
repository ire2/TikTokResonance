100294985251, "no_speech_prob": 0.00045406114077195525}, {"id": 52, "seek": 8660, "start": 98.47999999999999, "end": 99.88, "text": " Then I added in the iguana meat,", "tokens": [50958, 1396, 286, 3869, 294, 264, 8508, 20070, 4615, 11, 51028], "temperature": 0.0, "avg_logprob": -0.10501106175999184, "compression_ratio": 1.7994100294985251, "no_speech_prob": 0.00045406114077195525}, {"id": 53, "seek": 8660, "start": 99.88, "end": 101.56, "text": " topped it with some pickled red onions,", "tokens": [51028, 38781, 309, 365, 512, 38076, 2182, 13146, 11, 51112], "temperature": 0.0, "avg_logprob": -0.10501106175999184, "compression_ratio": 1.7994100294985251, "no_speech_prob": 0.00045406114077195525}, {"id": 54, "seek": 8660, "start": 101.56, "end": 104.47999999999999, "text": " jalapeno and cilantro and then drizzled on our sauce.", "tokens": [51112, 43089, 569, 5808, 293, 43626, 293, 550, 1630, 4313, 1493, 322, 527, 4880, 13, 51258], "temperature": 0.0, "avg_logprob": -0.10501106175999184, "compression_ratio": 1.7994100294985251, "no_speech_prob": 0.00045406114077195525}, {"id": 55, "seek": 8660, "start": 104.47999999999999, "end": 106.28, "text": " And there we have it, iguana tacos.", "tokens": [51258, 400, 456, 321, 362, 309, 11, 8508, 20070, 34776, 13, 51348], "temperature": 0.0, "avg_logprob": -0.10501106175999184, "compression_ratio": 1.7994100294985251, "no_speech_prob": 0.00045406114077195525}, {"id": 56, "seek": 8660, "start": 106.28, "end": 107.56, "text": " It looked good and they smell good,", "tokens": [51348, 467, 2956, 665, 293, 436, 4316, 665, 11, 51412], "temperature": 0.0, "avg_logprob": -0.10501106175999184, "compression_ratio": 1.7994100294985251, "no_speech_prob": 0.00045406114077195525}, {"id": 57, "seek": 8660, "start": 107.56, "end": 109.56, "text": " but now it's time to see how they taste.", "tokens": [51412, 457, 586, 309, 311, 565, 281, 536, 577, 436, 3939, 13, 51512], "temperature": 0.0, "avg_logprob": -0.10501106175999184, "compression_ra